{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "files": [
    "src/theme/Theme.d.ts",
    "src/Types/components.d.ts",
    "src/Types/screens.d.ts"
  ]
}

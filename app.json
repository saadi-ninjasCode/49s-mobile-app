{
  "expo": {
    "name": "UK 49's Results",
    "slug": "49s-mobile-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "jsEngine": "hermes",
    "icon": "./assets/images/icon.png",
    "scheme": "uk49sresults",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon-foreground.png",
        "monochromeImage": "./assets/images/icon-monochrome.png",
        "backgroundColor": "#253779"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.aqeel.uk49sresults"
    },
    "platforms": ["ios", "android"],
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#253779",
          "image": "./assets/images/logo-image.png",
          "imageWidth": 170,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#253779",
            "image": "./assets/images/logo-image.png"
          },
          "android": {
            "backgroundColor": "#253779",
            "image": "./assets/images/logo-image.png",
            "imageWidth": 170,
            "resizeMode": "contain",
            "dark": {
              "backgroundColor": "#253779",
              "image": "./assets/images/logo-image.png"
            }
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableMinifyInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "useLegacyPackaging": true
            // "buildArchs": [
            //   "arm64-v8a",
            //   "armeabi-v7a"
            // ]
          }
        }
      ],
      // "./plugins/withApkSizeTweaks",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
